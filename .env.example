# ─────────────────────────────────────────────
# Legal AI Workflow – Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env directly.
# ─────────────────────────────────────────────

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/legal-ai

# Gemini API Key (optional – used as fallback if Ollama is offline)
GEMINI_API_KEY=your_gemini_api_key_here

# Document Encryption Key – Must be exactly 32 characters (AES-256)
DOCUMENT_ENCRYPTION_KEY=your_32_character_encryption_key_

# JWT Secret for auth tokens
JWT_SECRET=your_super_secret_jwt_key_here

# Server Port (optional, defaults to 5000)
PORT=5000
